{
  "expo": {
    "name": "Home Plate Cook",
    "slug": "homeplate-cook",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "homeplatecook",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1B2B4B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.homeplate.cook"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1B2B4B"
      },
      "package": "com.homeplate.cook"
    },
    "plugins": [
      "expo-router"
    ]
  }
}